# Copy to .env and edit. The service reads these from the environment.

# --- Mode -------------------------------------------------------------
# 1/true → canned answers, NO API key and NO google-genai needed (default).
# Flip to 0 once GEMINI_API_KEY + ASK_STORE are set, for real answers.
ASK_STUB=1

# --- Gemini (live mode only) -----------------------------------------
GEMINI_API_KEY=
# File Search store resource name printed by the ingest job, e.g.
#   fileSearchStores/tipitaka-en-xxxxxxxx
ASK_STORE=
# Flash-class generation model — confirm the current name at build time
# (design Appendix A).
ASK_MODEL=gemini-2.5-flash
# Optional separate (cheaper) model for the query-rewrite/translate step.
# Defaults to ASK_MODEL if unset.
ASK_REWRITE_MODEL=
# Optional path to a newline-delimited list of real uids. When present, the
# linkifier drops refs that aren't in it (design §11.9). Emit it from ingest.
ASK_UID_MANIFEST=

# --- Service ----------------------------------------------------------
# Comma-separated allowed CORS origins, or * for any (dev only).
ASK_CORS_ORIGINS=*
# Optional shared secret. If set, callers must send header X-App-Token with it.
ASK_APP_TOKEN=
# Local dev port (8080 is the Dart web content server). Cloud Run injects PORT.
PORT=8081

# --- Ingest -----------------------------------------------------------
# Local checkout of github.com/suttacentral/bilara-data (published branch).
BILARA_DATA_DIR=../bilara-data
